    "editor.deleteActionMessage": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This action will be removed from the context menu. This cannot be undone. The script file will not be deleted."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该动作将从右键菜单移除,此操作不可撤销。脚本文件不会被删除。"
          }
        }
      }
    },
    "editor.deleteConfirm": {
      "localizations": {
        "en": {
          "stringUnit": {
