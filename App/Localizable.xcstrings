        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "3–4 system permission prompts will appear in sequence; just click \"Allow\" on each. Each is asked only once and applies permanently once granted."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
